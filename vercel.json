{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "experimentalServices": {
    "api": {
      "entrypoint": "backend/server.js",
      "routePrefix": "/api"
    }
  }
}